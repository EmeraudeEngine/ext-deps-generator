diff --git a/CMakeLists.txt b/CMakeLists.txt
new file mode 100644
index 0000000..38b9c2a
--- /dev/null
+++ b/CMakeLists.txt
@@ -0,0 +1,64 @@
+cmake_minimum_required(VERSION 3.20)
+project(ufbx LANGUAGES C VERSION 0.21.3)
+
+# Minimal static-library build for the single-translation-unit FBX parser.
+# Upstream does not ship a CMakeLists.txt; this is added by the
+# ext-deps-generator patch system to expose `ufbx.c` as a clean static lib.
+
+include(GNUInstallDirs)
+include(CMakePackageConfigHelpers)
+
+add_library(ufbx STATIC
+    ufbx.c
+)
+
+set_target_properties(ufbx PROPERTIES
+    C_STANDARD 99
+    C_STANDARD_REQUIRED ON
+    POSITION_INDEPENDENT_CODE ON
+)
+
+target_include_directories(ufbx
+    PUBLIC
+        $<BUILD_INTERFACE:${CMAKE_CURRENT_SOURCE_DIR}>
+        $<INSTALL_INTERFACE:${CMAKE_INSTALL_INCLUDEDIR}/ufbx>
+)
+
+# Third-party code, suppress warnings.
+if (MSVC)
+    target_compile_options(ufbx PRIVATE /w)
+else()
+    target_compile_options(ufbx PRIVATE -w)
+endif()
+
+# ufbx is a zero-dependency C library, but it does need libm on Unix.
+if (UNIX)
+    target_link_libraries(ufbx PUBLIC m)
+endif()
+
+install(TARGETS ufbx
+    EXPORT ufbxTargets
+    ARCHIVE DESTINATION ${CMAKE_INSTALL_LIBDIR}
+    LIBRARY DESTINATION ${CMAKE_INSTALL_LIBDIR}
+)
+
+install(FILES
+    ufbx.h
+    DESTINATION ${CMAKE_INSTALL_INCLUDEDIR}/ufbx
+)
+
+install(EXPORT ufbxTargets
+    FILE ufbxTargets.cmake
+    NAMESPACE ufbx::
+    DESTINATION ${CMAKE_INSTALL_LIBDIR}/cmake/ufbx
+)
+
+configure_package_config_file(
+    "${CMAKE_CURRENT_SOURCE_DIR}/ufbxConfig.cmake.in"
+    "${CMAKE_CURRENT_BINARY_DIR}/ufbxConfig.cmake"
+    INSTALL_DESTINATION ${CMAKE_INSTALL_LIBDIR}/cmake/ufbx
+)
+
+install(FILES "${CMAKE_CURRENT_BINARY_DIR}/ufbxConfig.cmake"
+    DESTINATION ${CMAKE_INSTALL_LIBDIR}/cmake/ufbx
+)
